{
    "name": "compact-vscode",
    "displayName": "Compact Syntax Highlighting",
    "description": "Syntax highlighting for Compact smart contract language (Midnight network)",
    "version": "0.3.2",
    "publisher": "foxytanuki",
    "repository": {
        "type": "git",
        "url": "https://github.com/foxytanuki/compact-vscode.git"
    },
    "license": "MIT",
    "engines": {
        "vscode": "^1.60.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "compact",
        "midnight",
        "midnight-network",
        "smart-contract",
        "blockchain",
        "vscode-extension"
    ],
    "contributes": {
        "languages": [
            {
                "id": "compact",
                "aliases": [
                    "Compact",
                    "compact"
                ],
                "extensions": [
                    ".compact"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "compact",
                "scopeName": "source.compact",
                "path": "./syntaxes/compact.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "bun run bundle",
        "compile": "tsc -p ./",
        "bundle": "bun run scripts/bundle.js",
        "watch": "tsc -watch -p ./",
        "pretest": "bun run compile && bun run lint",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "test": "bun run scripts/test.js",
        "dev:setup": "bun run compile",
        "dev:test": "bun run dev:setup && code --extensionDevelopmentPath=$(pwd)"
    },
    "devDependencies": {
        "@biomejs/biome": "latest",
        "@types/node": "^25.0.3",
        "@types/vscode": "^1.60.0",
        "esbuild": "^0.27.2",
        "typescript": "^5.9.3"
    }
}
